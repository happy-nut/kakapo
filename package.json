{
  "name": "@happy-nut/monacori",
  "version": "0.1.30",
  "description": "Validation control plane for AI-generated code changes.",
  "type": "module",
  "main": "dist/app-main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happy-nut/monacori.git"
  },
  "bugs": {
    "url": "https://github.com/happy-nut/monacori/issues"
  },
  "homepage": "https://github.com/happy-nut/monacori#readme",
  "bin": {
    "monacori": "bin/monacori.js",
    "mo": "bin/monacori.js"
  },
  "files": [
    "bin",
    "dist",
    "assets",
    "scripts/patch-electron-name.mjs",
    "scripts/record-demo.mjs",
    "scripts/benchmark.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-viewer-assets.mjs",
    "dev": "npm run build && MONACORI_DEV=1 node bin/monacori.js --foreground",
    "icon": "node scripts/gen-icon.mjs",
    "postinstall": "node scripts/patch-electron-name.mjs",
    "prepare": "npm run build",
    "demo:gif": "npm run build && electron scripts/record-demo.mjs",
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "smoke": "npm run build && node dist/cli.js --help",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "dist:mac": "npm run build && electron-packager . Monacori --platform=darwin --arch=arm64 --icon=assets/icon.icns --app-bundle-id=dev.happynut.monacori --app-category-type=public.app-category.developer-tools --out=release --overwrite --no-asar --ignore=/src/ --ignore=/test/ --ignore=/release --ignore=/.git --ignore=/.github --ignore=/.omc --ignore=/node_modules/electron/ --ignore=/node_modules/@electron --ignore=/node_modules/jsdom --ignore=/node_modules/monaco-editor",
    "dist:mac:dmg": "npm run dist:mac && create-dmg --overwrite --no-code-sign --dmg-title=Monacori 'release/Monacori-darwin-arm64/Monacori.app' release/ || true"
  },
  "keywords": [
    "ai",
    "code-review",
    "diff",
    "testing",
    "verification"
  ],
  "author": "happy-nut <happynut.dev@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@types/node": "^22.15.21",
    "dompurify": "3.4.12",
    "jsdom": "^29.1.1",
    "monaco-editor": "0.55.1",
    "terser": "^5.48.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vscode/ripgrep": "1.18.0",
    "diff2html": "^3.4.56",
    "electron": "42.4.1",
    "highlight.js": "^11.11.1",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0"
  },
  "optionalDependencies": {
    "create-dmg": "^8.1.0"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "3.4.12"
    }
  }
}

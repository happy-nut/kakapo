{
  "name": "@happy-nut/kakapo",
  "version": "0.2.7",
  "description": "Local desktop review workspace for AI-generated code changes.",
  "type": "module",
  "main": "dist/app-main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happy-nut/kakapo.git"
  },
  "bugs": {
    "url": "https://github.com/happy-nut/kakapo/issues"
  },
  "homepage": "https://github.com/happy-nut/kakapo#readme",
  "bin": {
    "kakapo": "bin/kakapo.js"
  },
  "files": [
    "bin",
    "dist",
    "assets",
    "scripts/patch-electron-name.mjs",
    "scripts/fix-pty-spawn-helper.mjs",
    "scripts/install-language-servers.mjs",
    "scripts/verify-language-server-package.mjs",
    "scripts/create-dmg.mjs",
    "scripts/package-linux.mjs",
    "scripts/smoke-linux.mjs",
    "scripts/record-demo.mjs",
    "scripts/benchmark.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-viewer-assets.mjs",
    "dev": "npm run build && KAKAPO_DEV=1 node bin/kakapo.js --foreground",
    "icon": "node scripts/gen-icon.mjs",
    "postinstall": "node scripts/patch-electron-name.mjs && node scripts/fix-pty-spawn-helper.mjs",
    "prepare": "npm run build",
    "demo:gif": "npm run build && electron scripts/record-demo.mjs",
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "lsp:install": "node scripts/install-language-servers.mjs",
    "lsp:smoke": "node --test test/language-server-bundles.test.mjs",
    "smoke": "npm run build && node dist/cli.js --help",
    "pretest": "npm run build",
    "test": "node --test --test-concurrency=1 test/*.test.mjs",
    "pack:mac": "electron-packager . Kakapo --platform=darwin --arch=arm64 --icon=assets/icon.icns --app-bundle-id=dev.happynut.kakapo --app-category-type=public.app-category.developer-tools --out=release --overwrite --no-asar --ignore=/src/ --ignore=/test/ --ignore=/release --ignore=/.git --ignore=/.github --ignore=/.omc --ignore=/node_modules/electron/ --ignore=/node_modules/@electron --ignore=/node_modules/jsdom",
    "verify:mac": "node scripts/verify-language-server-package.mjs release/Kakapo-darwin-arm64/Kakapo.app/Contents/Resources/app darwin arm64",
    "dist:mac": "npm run lsp:install && npm run build && npm run lsp:smoke && npm run pack:mac && npm run verify:mac",
    "dist:mac:dmg": "npm run dist:mac && node scripts/create-dmg.mjs",
    "dist:mac:ci": "npm run lsp:install && npm run build && npm run pack:mac && npm run verify:mac",
    "dist:mac:dmg:ci": "npm run dist:mac:ci && node scripts/create-dmg.mjs",
    "dist:linux": "npm run dist:linux:x64",
    "dist:linux:x64": "npm run lsp:install && npm run build && npm run lsp:smoke && node scripts/package-linux.mjs x64",
    "dist:linux:arm64": "npm run lsp:install && npm run build && npm run lsp:smoke && node scripts/package-linux.mjs arm64",
    "smoke:linux": "node scripts/smoke-linux.mjs"
  },
  "keywords": [
    "ai",
    "code-review",
    "diff",
    "testing",
    "verification"
  ],
  "author": "happy-nut <happynut.dev@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@tiptap/core": "3.27.4",
    "@tiptap/extension-details": "3.27.4",
    "@tiptap/extension-task-item": "3.27.4",
    "@tiptap/extension-task-list": "3.27.4",
    "@tiptap/markdown": "3.27.4",
    "@tiptap/pm": "3.27.4",
    "@tiptap/starter-kit": "3.27.4",
    "@types/node": "^22.15.21",
    "dompurify": "3.4.12",
    "esbuild": "0.28.1",
    "jsdom": "^29.1.1",
    "markdown-it": "14.3.0",
    "terser": "^5.48.0"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "dependencies": {
    "@vscode/ripgrep": "1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "electron": "42.4.1",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0",
    "pyright": "1.1.411",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0"
  }
}
